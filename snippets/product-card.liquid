{% comment %} snippets/product-card.liquid
  Usage: {%- render 'product-card', product: product -%}
{% endcomment %}

{%- assign discount_pct = 0 -%}
{%- if product.compare_at_price > product.price -%}
  {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
{%- endif -%}

<div class="pcard" data-product-id="{{ product.id }}">

  {%- comment -%} Image area {%- endcomment -%}
  <a href="{{ product.url }}" class="pimg-wrap" aria-label="{{ product.title }}">

    {%- if product.metafields.reviews.rating_count > 10 -%}
      <div class="viewer-badge sp-badge">{{ product.metafields.custom.viewers | default: '12' }} viewing now</div>
    {%- endif -%}

    {%- comment -%} Badge {%- endcomment -%}
    {%- if product.tags contains 'best-seller' -%}
      <span class="pbadge bestseller">★ BEST SELLER</span>
    {%- elsif product.tags contains 'new-arrival' -%}
      <span class="pbadge newarrival">● NEW ARRIVAL</span>
    {%- elsif product.tags contains 'featured' -%}
      <span class="pbadge featured">✦ FEATURED</span>
    {%- endif -%}

    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 400 }}"
        alt="{{ product.featured_image.alt | default: product.title }}"
        loading="lazy"
        width="200"
        height="200"
        srcset="{{ product.featured_image | image_url: width: 200 }} 200w,
                {{ product.featured_image | image_url: width: 400 }} 400w"
        sizes="(min-width: 768px) 25vw, 50vw"
      >
    {%- else -%}
      <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;background:#f0f0f0">
        <span style="font-size:9px;color:#bbb;font-weight:700;letter-spacing:1px;text-transform:uppercase">No Image</span>
      </div>
    {%- endif -%}

    {%- unless product.available -%}
      <div class="cs-overlay"><span class="cs-label">SOLD OUT</span></div>
    {%- endunless -%}

  </a>

  {%- comment -%} Body {%- endcomment -%}
  <div class="pcard-body">

    {%- comment -%} Stars {%- endcomment -%}
    <div style="display:flex;align-items:center;gap:6px">
      <div class="stars">
        {%- for i in (1..5) -%}
          <svg width="10" height="10" style="color:#000"><use href="#ico-star"/></svg>
        {%- endfor -%}
      </div>
      <span style="font-size:9.5px;font-weight:800;color:#111;letter-spacing:.3px">5.0/5</span>
    </div>

    <p class="pname">{{ product.title }}</p>
    <p class="psub">{{ product.metafields.custom.subtitle | default: product.product_type }}</p>

    {%- comment -%} Price {%- endcomment -%}
    {%- if product.compare_at_price > product.price -%}
      <div class="price-row">
        <span class="pprice-orig">PKR {{ product.compare_at_price | money_without_currency }}</span>
        <span class="pprice-sale">PKR {{ product.price | money_without_currency }}</span>
        {%- if discount_pct > 0 -%}
          <span class="pprice-disc-badge">{{ discount_pct }}% OFF</span>
        {%- endif -%}
      </div>
    {%- else -%}
      <p class="pprice">PKR {{ product.price | money_without_currency }}</p>
    {%- endif -%}

    <p class="patch-note">⚠️ 24-hr patch test required before first use.</p>
  </div>

  {%- comment -%} Orders social proof {%- endcomment -%}
  {%- if product.available -%}
    <p class="orders-badge sp-badge">✅ {{ product.metafields.custom.orders_24h | default: '28' }} orders in last 24h</p>
  {%- endif -%}

  {%- comment -%} ATC Button {%- endcomment -%}
  {%- if product.available -%}
    {%- assign first_variant = product.variants.first -%}
    <button
      class="btn-atc"
      onclick="addToCart({{ first_variant.id }}, this)"
      aria-label="Add {{ product.title }} to cart"
    >ADD TO CART</button>
  {%- else -%}
    <button class="btn-atc btn-atc--disabled" disabled aria-disabled="true">SOLD OUT</button>
  {%- endif -%}

</div>
