{% comment %} templates/cart.liquid {% endcomment %}
{% section 'announcement-bar' %}
{% section 'header' %}

<div class="cart-page">
  <div class="wrap">
    <h1 class="cart-page-title">YOUR CART</h1>

    {%- if cart.item_count == 0 -%}
      <div style="text-align:center;padding:80px 20px">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#ddd" stroke-width="1.5" style="margin:0 auto 16px">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <p style="font-size:14px;font-weight:800;letter-spacing:1px;text-transform:uppercase;margin-bottom:16px">Your cart is empty</p>
        <a href="/collections/all" class="btn-blk">SHOP NOW →</a>
      </div>

    {%- else -%}
      <div class="cart-page-grid">

        <!-- Items -->
        <div>
          <div class="cart-page-items">
            {%- for item in cart.items -%}
              <div class="cart-page-item">
                <div class="cpi-img">
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.product.title }}" loading="lazy" width="80" height="80">
                </div>
                <div>
                  <p class="cpi-name">{{ item.product.title }}</p>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <p class="cpi-variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <p class="cpi-price">PKR {{ item.final_line_price | money_without_currency }}</p>
                  <div style="display:flex;align-items:center;gap:16px;margin-top:8px">
                    <div class="qty-ctrl">
                      <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}" class="qbtn" aria-label="Decrease">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                      </a>
                      <span class="qnum">{{ item.quantity }}</span>
                      <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}" class="qbtn" aria-label="Increase">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                      </a>
                    </div>
                    <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0" style="font-size:9px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:#bbb;text-decoration:underline">REMOVE</a>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>

        <!-- Summary -->
        <div class="cart-summary-box">
          <p class="csb-title">ORDER SUMMARY</p>
          <div class="csb-row"><span class="csb-label">Subtotal</span><span class="csb-value">PKR {{ cart.total_price | money_without_currency }}</span></div>
          {%- if cart.total_price >= 200000 -%}
            <div class="csb-row"><span class="csb-label">Shipping</span><span class="csb-value" style="color:#2d6a4f">FREE</span></div>
          {%- else -%}
            <div class="csb-row"><span class="csb-label">Shipping</span><span class="csb-value">PKR 250</span></div>
          {%- endif -%}
          <div class="csb-total">
            <span>TOTAL</span>
            <span>PKR {{ cart.total_price | money_without_currency }}</span>
          </div>

          <a href="/checkout" class="btn-checkout" style="display:block;text-align:center;text-decoration:none;margin-top:16px">PROCEED TO CHECKOUT →</a>

          <a href="https://wa.me/{{ settings.whatsapp_number | default: '923021345111' }}" class="btn-wa" target="_blank" rel="noopener" style="display:flex;margin-top:10px;text-decoration:none;justify-content:center">
            <svg width="18" height="18" style="margin-right:8px"><use href="#ico-wa"/></svg>
            ORDER VIA WHATSAPP
          </a>

          <a href="/collections/all" class="btn-continue" style="display:block;text-align:center;text-decoration:none;margin-top:8px">CONTINUE SHOPPING</a>

          <p style="font-size:9px;color:#bbb;text-align:center;margin-top:10px;letter-spacing:.3px">
            🔒 SECURE CHECKOUT · COD AVAILABLE
          </p>
        </div>

      </div>
    {%- endif -%}
  </div>
</div>

{% section 'footer' %}
