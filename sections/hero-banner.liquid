{% comment %} sections/hero-banner.liquid {% endcomment %}

<!-- ══ HERO POSTER ══ -->
<section class="hero-poster" aria-label="Hero Banner">
  <div class="hp-wrap">

    <!-- LEFT COPY -->
    <div class="hp-left">

      <div class="hp-eyebrow a1">
        <span class="hp-eyeline"></span>
        <span class="hp-eye-text">{{ section.settings.eyebrow_text }}</span>
      </div>

      <h1 class="hp-h1 a2">
        <span class="hp-h1-white">{{ section.settings.heading_line1 }}</span>
        <span class="hp-h1-white">{{ section.settings.heading_line2 }}</span>
        <span class="hp-h1-gold">{{ section.settings.heading_line3 }}<sup>™</sup></span>
      </h1>

      <p class="hp-sub a3">{{ section.settings.subheading }}</p>

      <div class="hp-badges a3">
        {%- for block in section.blocks -%}
          {%- if block.type == 'badge' -%}
            <span class="hp-badge" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="hp-btns a3">
        <a href="{{ section.settings.btn1_link }}" class="hp-btn-gold">{{ section.settings.btn1_text }}</a>
        <a href="{{ section.settings.btn2_link }}" class="hp-btn-outline">{{ section.settings.btn2_text }}</a>
      </div>

      {%- if section.settings.pakistan_label != blank -%}
        <p class="hp-pakistan">{{ section.settings.pakistan_label }}</p>
      {%- endif -%}

    </div>

    <!-- RIGHT: Products / Hero Image -->
    <div class="hp-right">

      <!-- Float badge top -->
      {%- if section.settings.show_float_badge_top -%}
        <div class="hp-float-badge">
          <span class="hp-fb-icon">☀️</span>
          <span class="hp-fb-text">
            <strong>{{ section.settings.float_badge_top_bold }}</strong>
            <small>{{ section.settings.float_badge_top_small }}</small>
          </span>
        </div>
      {%- endif -%}

      <!-- Product images row -->
      <div class="hp-products">

        {%- comment -%} Left back product {%- endcomment -%}
        {%- if section.settings.product_left != blank -%}
          {%- assign left_prod = section.settings.product_left -%}
          <div class="hp-prod hp-prod--back hp-prod--left">
            <img
              src="{{ left_prod.featured_image | image_url: width: 200 }}"
              alt="{{ left_prod.title }}"
              loading="lazy"
              width="68"
              height="auto"
              style="width:68px;height:auto;filter:drop-shadow(0 10px 20px rgba(0,0,0,.6))"
            >
            <span class="hp-prod-name">{{ left_prod.title | truncatewords: 3 }}</span>
          </div>
        {%- elsif section.settings.hero_image != blank -%}
          {%- comment -%} Fallback SVG if no product set {%- endcomment -%}
        {%- endif -%}

        {%- comment -%} Center main product {%- endcomment -%}
        {%- if section.settings.product_center != blank -%}
          {%- assign center_prod = section.settings.product_center -%}
          <div class="hp-prod hp-prod--main">
            <img
              src="{{ center_prod.featured_image | image_url: width: 300 }}"
              alt="{{ center_prod.title }}"
              loading="eager"
              width="100"
              height="auto"
              style="width:100px;height:auto;filter:drop-shadow(0 10px 20px rgba(0,0,0,.6))"
            >
            <span class="hp-prod-name hp-prod-name--main">{{ center_prod.title | truncatewords: 3 }}</span>
            <span class="hp-prod-price">PKR {{ center_prod.price | divided_by: 100 | money_without_currency }}</span>
          </div>
        {%- elsif section.settings.hero_image != blank -%}
          <div class="hp-prod hp-prod--main">
            <img
              src="{{ section.settings.hero_image | image_url: width: 400 }}"
              alt="{{ shop.name }} products"
              loading="eager"
              width="130"
              height="auto"
              style="width:130px;height:auto;filter:drop-shadow(0 10px 20px rgba(0,0,0,.6))"
            >
          </div>
        {%- else -%}
          {%- comment -%} Default SVG placeholder {%- endcomment -%}
          <div class="hp-prod hp-prod--main">
            <svg viewBox="0 0 100 340" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100px;height:auto;filter:drop-shadow(0 10px 20px rgba(0,0,0,.6))">
              <defs>
                <linearGradient id="mb1h" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#b8c8cc"/><stop offset="50%" stop-color="#f0f8fc"/><stop offset="100%" stop-color="#b0c0c4"/></linearGradient>
                <linearGradient id="mg1h" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#9a7a2a"/><stop offset="50%" stop-color="#e8d080"/><stop offset="100%" stop-color="#9a7a2a"/></linearGradient>
              </defs>
              <rect x="44" y="0" width="12" height="7" rx="2" fill="#aaa"/><rect x="48" y="7" width="4" height="56" rx="2" fill="#aaa"/>
              <rect x="30" y="18" width="26" height="7" rx="3.5" fill="#999"/>
              <path d="M14 74 Q4 84 2 98 L98 98 Q96 84 86 74Z" fill="#c4d0d4"/>
              <rect x="0" y="96" width="100" height="230" rx="14" fill="url(#mb1h)" stroke="#b8c4c8" stroke-width=".8"/>
              <rect x="6" y="140" width="88" height="160" rx="4" fill="#fff" opacity=".93"/>
              <text x="50" y="168" text-anchor="middle" font-family="Montserrat,sans-serif" font-size="15" font-weight="900" fill="#0a0a0a" letter-spacing="2.5">OSISS</text>
              <line x1="12" y1="174" x2="88" y2="174" stroke="#e8e8e8" stroke-width=".8"/>
              <text x="50" y="194" text-anchor="middle" font-family="Montserrat,sans-serif" font-size="8" font-weight="900" fill="#111" letter-spacing="1">GENTLE FOAMING</text>
              <text x="50" y="206" text-anchor="middle" font-family="Montserrat,sans-serif" font-size="8" font-weight="900" fill="#111" letter-spacing="1">CLEANSER</text>
              <rect x="6" y="212" width="88" height="2.5" fill="url(#mg1h)" opacity=".65"/>
              <text x="50" y="264" text-anchor="middle" font-family="Montserrat,sans-serif" font-size="6" font-weight="700" fill="#c8a951" letter-spacing=".8">PCSIR · DRAP · GMP</text>
            </svg>
            <span class="hp-prod-name hp-prod-name--main">Gentle Foaming Cleanser</span>
            <span class="hp-prod-price">PKR 1,500</span>
          </div>
        {%- endif -%}

        {%- comment -%} Right back product {%- endcomment -%}
        {%- if section.settings.product_right != blank -%}
          {%- assign right_prod = section.settings.product_right -%}
          <div class="hp-prod hp-prod--back hp-prod--right">
            <img
              src="{{ right_prod.featured_image | image_url: width: 200 }}"
              alt="{{ right_prod.title }}"
              loading="lazy"
              width="68"
              height="auto"
              style="width:68px;height:auto;filter:drop-shadow(0 10px 20px rgba(0,0,0,.6))"
            >
            <span class="hp-prod-name">{{ right_prod.title | truncatewords: 3 }}</span>
          </div>
        {%- endif -%}

      </div>

      <!-- Float badge bottom -->
      {%- if section.settings.show_float_badge_bottom -%}
        <div class="hp-float-badge hp-float-bottom">
          <span class="hp-fb-icon">⭐</span>
          <span class="hp-fb-text">
            <strong>{{ section.settings.float_badge_bottom_bold }}</strong>
            <small>{{ section.settings.float_badge_bottom_small }}</small>
          </span>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "div",
  "class": "hero-section",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Hero Copy"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "DERMATOLOGY BACKED INNOVATION"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading line 1",
      "default": "SCIENCE"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading line 2",
      "default": "BACKED"
    },
    {
      "type": "text",
      "id": "heading_line3",
      "label": "Heading line 3 (gold)",
      "default": "SKINCARE"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Where Dermatology Meets Daily Beauty Rituals."
    },
    {
      "type": "text",
      "id": "pakistan_label",
      "label": "Pakistan label",
      "default": "🇵🇰 PROUDLY MADE IN PAKISTAN"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 text",
      "default": "SHOP NOW →"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 text",
      "default": "OUR STORY"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Button 2 link"
    },
    {
      "type": "header",
      "content": "Products (Hero Right)"
    },
    {
      "type": "product",
      "id": "product_center",
      "label": "Center (main) product"
    },
    {
      "type": "product",
      "id": "product_left",
      "label": "Left background product"
    },
    {
      "type": "product",
      "id": "product_right",
      "label": "Right background product"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Or: Hero product image (if no products set above)"
    },
    {
      "type": "header",
      "content": "Float Badges"
    },
    {
      "type": "checkbox",
      "id": "show_float_badge_top",
      "label": "Show top float badge",
      "default": true
    },
    {
      "type": "text",
      "id": "float_badge_top_bold",
      "label": "Top badge bold text",
      "default": "SPF 50+ PA++++"
    },
    {
      "type": "text",
      "id": "float_badge_top_small",
      "label": "Top badge small text",
      "default": "Broad Spectrum Shield"
    },
    {
      "type": "checkbox",
      "id": "show_float_badge_bottom",
      "label": "Show bottom float badge",
      "default": true
    },
    {
      "type": "text",
      "id": "float_badge_bottom_bold",
      "label": "Bottom badge bold text",
      "default": "4.9/5 from 2,500+ reviews"
    },
    {
      "type": "text",
      "id": "float_badge_bottom_small",
      "label": "Bottom badge small text",
      "default": "Verified Customers"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "PCSIR"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "badge", "settings": { "text": "PCSIR" } },
        { "type": "badge", "settings": { "text": "DRAP" } },
        { "type": "badge", "settings": { "text": "GMP" } },
        { "type": "badge", "settings": { "text": "🌿 CRUELTY-FREE" } }
      ]
    }
  ]
}
{% endschema %}
