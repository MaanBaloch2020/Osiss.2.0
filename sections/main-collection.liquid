{% comment %} sections/main-collection.liquid {% endcomment %}

<section class="collection-page">
  <div class="wrap">

    <div class="collection-hdr">
      <h1 class="collection-title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="collection-desc">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    <div class="collection-toolbar">
      <span class="ct-count">{{ collection.products_count }} products</span>
      <div class="ct-sort">
        <label for="collectionSort">Sort:</label>
        <select id="collectionSort" name="sort_by" aria-label="Sort products">
          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>
              {{ option.name }}
            </option>
          {%- endfor -%}
        </select>
      </div>
    </div>

    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- if collection.products.size > 0 -%}
        <div class="pgrid">
          {%- for product in collection.products -%}
            {%- render 'product-card', product: product -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div style="display:flex;justify-content:center;gap:8px;margin-top:40px;flex-wrap:wrap">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="btn-blk">← PREV</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="btn-blk">{{ part.title }}</a>
              {%- else -%}
                <span class="btn-blk" style="background:#000;color:#fff">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="btn-blk">NEXT →</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div style="text-align:center;padding:80px 20px">
          <p style="font-size:12px;font-weight:700;letter-spacing:2px;color:#bbb;text-transform:uppercase;margin-bottom:8px">Coming Soon</p>
          <p style="font-size:13px;color:#aaa">New products launching in this collection soon.</p>
        </div>
      {%- endif -%}
    {%- endpaginate -%}

  </div>
</section>

{% schema %}
{
  "name": "Collection Page",
  "tag": "div",
  "class": "collection-page-section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16,
      "label": "Products per page"
    }
  ],
  "presets": [
    { "name": "Collection Page" }
  ]
}
{% endschema %}
